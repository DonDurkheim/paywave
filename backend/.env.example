# PayWave - RFID Payment System Configuration
# Copy this file to .env and fill in your values

# Server Port
PORT=9264

# MongoDB Connection String
# Get this from your MongoDB Atlas dashboard or use a local MongoDB instance
# Format: mongodb+srv://username:password@cluster-url/?options
MONGODB_URI=your_mongodb_connection_string_here

# Database Name
DB_NAME=paywave

# MQTT Broker URL
# Format: mqtt://ip:port or mqtts://ip:port for TLS
MQTT_BROKER=mqtt://157.173.101.159:1883
